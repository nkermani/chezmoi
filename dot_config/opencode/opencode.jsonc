{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-gemini-auth@latest",
    "oh-my-opencode@latest"
  ],
  "default_agent": "42-NK",
  "provider": {
    "google": {
      "options": {
        "projectId": "opencode-42",
        "timeout": 600000
      }
    }
  },
  "mcp": {
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "@mauricio.wolff/mcp-obsidian@latest",
        "/path/to/your/vault/"
      ],
      "enabled": true
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    }
  }
}

