    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": ["comment", "punctuation.definition.comment"],
                "settings": { "foreground": "#777777", "fontStyle": "italic" }
            },
            {
                "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control", "keyword.operator"],
                "settings": { "foreground": "#f3505c" }
            },
            {
                "scope": ["entity.name.function", "support.function", "variable.function"],
                "settings": { "foreground": "#00f0ff" }
            },
            {
                "scope": ["string", "punctuation.definition.string"],
                "settings": { "foreground": "#eedb85" }
            },
            {
                "scope": ["constant.numeric", "constant.language.boolean"],
                "settings": { "foreground": "#368aec" }
            },
            {
                "scope": ["constant.language", "constant.character", "constant.other"],
                "settings": { "foreground": "#d867c6" }
            },
            {
                "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
                "settings": { "foreground": "#51f66f" }
            },
            {
                "scope": ["variable", "identifier"],
                "settings": { "foreground": "#cacaca" }
            },
            {
                "scope": ["entity.other.attribute-name", "variable.parameter"],
                "settings": { "foreground": "#ff9e64" }
            },
            {
                "scope": ["entity.name.tag", "meta.tag"],
                "settings": { "foreground": "#f3505c" }
            },
            {
                "scope": ["markup.heading"],
                "settings": { "foreground": "#f3505c", "fontStyle": "bold" }
            },
            {
                "scope": ["markup.bold"],
                "settings": { "foreground": "#eedb85", "fontStyle": "bold" }
            },
            {
                "scope": ["markup.italic"],
                "settings": { "foreground": "#d867c6", "fontStyle": "italic" }
            },
            {
                "scope": ["markup.underline"],
                "settings": { "foreground": "#00f0ff", "fontStyle": "underline" }
            },
            {
                "scope": ["markup.quote"],
                "settings": { "foreground": "#51f66f", "fontStyle": "italic" }
            },
            {
                "scope": ["markup.list", "markup.raw"],
                "settings": { "foreground": "#ff9e64" }
            },
            {
                "scope": ["meta.link", "markup.underline.link"],
                "settings": { "foreground": "#00f0ff" }
            },
            {
                "scope": ["token.info-token"],
                "settings": { "foreground": "#368aec" }
            },
            {
                "scope": ["token.warn-token"],
                "settings": { "foreground": "#eedb85" }
            },
            {
                "scope": ["token.error-token"],
                "settings": { "foreground": "#f3505c" }
            },
            {
                "scope": ["token.debug-token"],
                "settings": { "foreground": "#d867c6" }
            }
        ]
    },
