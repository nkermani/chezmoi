#!/bin/bash
{{ include ".chezmoitemplates/env.sh.tmpl" }}

echo "⚙️  Setting up runtimes..."
# Node via NVM
if [[ "$IS_42" == "true" ]]; then
    export NVM_DIR="/goinfre/$USER/.nvm"
else
    export NVM_DIR="$APPS_DIR/nvm"
fi
mkdir -p "$NVM_DIR"

if [ ! -d "$NVM_DIR/versions" ]; then
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | NVM_DIR="$NVM_DIR" bash
fi
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

if ! command -v node &>/dev/null; then
    nvm install 22 && nvm use 22 && nvm alias default 22
    ln -sf "$(which node)" "$BIN_DIR/node"
    ln -sf "$(which npm)" "$BIN_DIR/npm"
fi

# Rust
if [[ "$IS_42" == "true" ]]; then
    export RUSTUP_HOME="/goinfre/$USER/.rustup"
    export CARGO_HOME="/goinfre/$USER/.cargo"
    export PATH="$CARGO_HOME/bin:$PATH"
    mkdir -p "$RUSTUP_HOME" "$CARGO_HOME" "$RUSTUP_HOME/tmp" "$RUSTUP_HOME/dl"
    export RUSTUP_DL_DIR="$RUSTUP_HOME/dl"
    export TMPDIR="$RUSTUP_HOME/tmp"
fi

if ! command -v cargo &>/dev/null; then
    echo "  🦀 Installing Rust..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path
fi

# Ensure default toolchain is set and rust-src is installed for rust-analyzer
if [[ "$IS_42" == "true" ]]; then
    export RUSTUP_HOME="/goinfre/$USER/.rustup"
    export CARGO_HOME="/goinfre/$USER/.cargo"
    mkdir -p "$RUSTUP_HOME" "$CARGO_HOME" "$RUSTUP_HOME/tmp" "$RUSTUP_HOME/dl" 2>/dev/null
    export RUSTUP_DL_DIR="$RUSTUP_HOME/dl"
    export TMPDIR="$RUSTUP_HOME/tmp"
fi
echo "  🦀 Checking toolchain..."
if command -v rustup &>/dev/null; then
    if ! rustup show active-toolchain &>/dev/null; then
        echo "  🦀 Setting default toolchain..."
        rustup default stable 2>/dev/null || true
    fi
    echo "  🦀 Adding rust-src component..."
    rustup component add rust-src 2>/dev/null || echo "  ⚠️ rust-src failed, continuing..."
fi

# Flutter & Dart
if [ ! -L "$BIN_DIR/flutter" ]; then
    echo "  🐦 Installing Flutter..."
    FLUTTER_VER="3.41.4"
    FLUTTER_ARCHIVE="flutter_linux_${FLUTTER_VER}-stable.tar.xz"
    
    # Use goinfre for 42 to avoid quota issues
    if [[ "$IS_42" == "true" ]]; then
        FLUTTER_ROOT="/goinfre/$USER/flutter"
    else
        FLUTTER_ROOT="$APPS_DIR/flutter"
    fi
    
    # Clean up if it was accidentally installed in bin
    [ -d "$BIN_DIR/flutter" ] && rm -rf "$BIN_DIR/flutter"
    
    if [ ! -d "$FLUTTER_ROOT" ]; then
        curl -LSs "https://storage.googleapis.com/flutter_infra_release/releases/stable/linux/${FLUTTER_ARCHIVE}" -o /tmp/flutter.tar.xz
        mkdir -p "$(dirname "$FLUTTER_ROOT")"
        tar -xf /tmp/flutter.tar.xz -C "$(dirname "$FLUTTER_ROOT")"
        rm /tmp/flutter.tar.xz
    fi
    
    ln -sf "$FLUTTER_ROOT/bin/flutter" "$BIN_DIR/flutter"
    ln -sf "$FLUTTER_ROOT/bin/dart" "$BIN_DIR/dart"
fi

# Android SDK (Command Line Tools)
if [ ! -d "$NK_DIR/android-sdk" ] && [ ! -d "/goinfre/$USER/android-sdk" ]; then
    echo "  🤖 Installing Android SDK (cmdline-tools)..."
    CMDLINE_VER="14742923"
    
    if [[ "$IS_42" == "true" ]]; then
        ANDROID_HOME="/goinfre/$USER/android-sdk"
    else
        ANDROID_HOME="$NK_DIR/android-sdk"
    fi
    
    if [ ! -d "$ANDROID_HOME" ]; then
        mkdir -p "$ANDROID_HOME/cmdline-tools"
        curl -LSs "https://dl.google.com/android/repository/commandlinetools-linux-${CMDLINE_VER}_latest.zip" -o /tmp/cmdline.zip
        unzip -o /tmp/cmdline.zip -d "/tmp/android-cmdline"
        mv "/tmp/android-cmdline/cmdline-tools" "$ANDROID_HOME/cmdline-tools/latest"
        rm -rf /tmp/cmdline.zip /tmp/android-cmdline
        
        # Initial SDK setup (Platform 36, Build-tools 36.0.0)
        yes | "$ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager" --sdk_root="$ANDROID_HOME" "platform-tools" "build-tools;36.0.0" "platforms;android-36"
    fi
    
    # Link adb to bin
    [ -f "$ANDROID_HOME/platform-tools/adb" ] && ln -sf "$ANDROID_HOME/platform-tools/adb" "$BIN_DIR/adb"
fi
