#!/bin/bash

# Set template variables directly
IS_42="{{ .is_42 }}"
HAS_SUDO="{{ .has_sudo }}"

# Include env.sh.tmpl for other variables
{{ include ".chezmoitemplates/env.sh.tmpl" }}

echo "🌙 Configuring Neovim..."
if [ ! -f "$BIN_DIR/nvim" ]; then
    NVIM_INSTALL_DIR="$APPS_DIR/nvim-nightly"
    mkdir -p "$NVIM_INSTALL_DIR"
    if [[ "$OS_TYPE" == "Darwin" ]]; then
        # Native Apple Silicon support
        local MACOS_ARCH="x86_64"
        [[ "$(uname -m)" == "arm64" ]] && MACOS_ARCH="arm64"
        curl -LSs "https://github.com/neovim/neovim/releases/download/nightly/nvim-macos-${MACOS_ARCH}.tar.gz" | tar -xzC "$NVIM_INSTALL_DIR" --strip-components=1
    else
        local NVIM_ARCH="x86_64"
        [[ "$ARCH_TYPE" == "aarch64" || "$ARCH_TYPE" == "arm64" ]] && NVIM_ARCH="arm64"
        curl -LSs "https://github.com/neovim/neovim/releases/download/nightly/nvim-linux-${NVIM_ARCH}.tar.gz" | tar -xzC "$NVIM_INSTALL_DIR" --strip-components=1
    fi
    ln -sf "$NVIM_INSTALL_DIR/bin/nvim" "$BIN_DIR/nvim"
fi

# Plugin installation
INSTALL_PLUGINS_SCRIPT="$HOME/.config/nvim_nkermani/scripts/install-nvim-plugins.sh"
if [ -f "$INSTALL_PLUGINS_SCRIPT" ]; then
    chmod +x "$INSTALL_PLUGINS_SCRIPT" && bash "$INSTALL_PLUGINS_SCRIPT"
fi

echo "🛠️  Setting up LSP servers (sudoless via npm)..."

install_npm_lsp() {
    local name=$1
    local package=$2
    local binary=$3
    if [ ! -f "$LSP_BIN_DIR/$binary" ]; then
        if ! command -v npm &>/dev/null; then
            echo "  ⚠️  npm not found, skipping $name."
            return
        fi
        echo "  📦 Installing $name..."
        CI=true npm install -g $package --prefix "$APPS_DIR/$name" \
            --no-audit --no-fund --loglevel error </dev/null
        ln -sf "$APPS_DIR/$name/bin/$binary" "$LSP_BIN_DIR/$binary"
    fi
}

install_npm_lsp "pyright" "pyright" "pyright-langserver"
install_npm_lsp "typescript-lsp" "typescript typescript-language-server" "typescript-language-server"
install_npm_lsp "bash-lsp" "bash-language-server" "bash-language-server"
install_npm_lsp "dotenv-lsp" "dot-language-server" "dot-language-server"

# --- EDITOR INSTALLATIONS ---
echo "📝 Installing editors..."

# 1. VSCode (only install if not already in custom location)
if [ ! -f "$BIN_DIR/code" ]; then
    echo "  💜 Installing VSCode..."
    VSCODE_DIR="$APPS_DIR/vscode"
    mkdir -p "$VSCODE_DIR"

    VSCODE_ARCH="x64"
    [[ "$ARCH_TYPE" == "aarch64" || "$ARCH_TYPE" == "arm64" ]] && VSCODE_ARCH="arm64"

    if [[ "$OS_TYPE" == "Darwin" ]]; then
        if [[ "$VSCODE_ARCH" == "arm64" ]]; then
            curl -LSs "https://update.code.visualstudio.com/latest/darwin-arm64/stable" -o /tmp/VSCode-darwin-arm64.zip
        else
            curl -LSs "https://update.code.visualstudio.com/latest/darwin-x64/stable" -o /tmp/VSCode-darwin-x64.zip
        fi
        unzip -q /tmp/VSCode-*.zip -d "$VSCODE_DIR"
        ln -sf "$VSCODE_DIR/Visual\ Studio\ Code.app/Contents/Resources/app/bin/code" "$BIN_DIR/code"
        rm -f /tmp/VSCode-*.zip
    else
        curl -LSs "https://update.code.visualstudio.com/latest/linux-${VSCODE_ARCH}/stable" -o /tmp/vscode.tar.gz
        tar -xzf /tmp/vscode.tar.gz -C "$VSCODE_DIR" --strip-components=1
        ln -sf "$VSCODE_DIR/bin/code" "$BIN_DIR/code"
        rm -f /tmp/vscode.tar.gz
    fi
fi

# Affine (stable channel)
# Uses a fixed GitHub release artifact (Linux x64 ZIP). Replace the URL if you want a newer version.
if [ ! -f "$BIN_DIR/affine" ]; then
    echo "  🎨 Installing Affine..."
    AFFINE_DIR="$APPS_DIR/affine"
    mkdir -p "$AFFINE_DIR"

    AFFINE_URL="https://github.com/toeverything/AFFiNE/releases/download/v0.26.3/affine-0.26.3-stable-linux-x64.zip"
    AFFINE_ARCHIVE="/tmp/affine-stable.zip"

    curl -fsSL "$AFFINE_URL" -o "$AFFINE_ARCHIVE"

    # Extract into the app dir (overwrite any previous content)
    rm -rf "$AFFINE_DIR"/*
    unzip -oq "$AFFINE_ARCHIVE" -d "$AFFINE_DIR"

    # Symlink the executable
    if [[ -x "$AFFINE_DIR/AFFiNE-linux-x64/AFFiNE" ]]; then
        ln -sf "$AFFINE_DIR/AFFiNE-linux-x64/AFFiNE" "$BIN_DIR/affine"
        echo "  ✅ Affine installed to $BIN_DIR/affine"

        # Create a desktop entry for Linux (and install the official icon)
        if [[ "$OS_TYPE" == "Linux" ]]; then
            mkdir -p "$HOME/.local/share/applications"

            ICON_THEME_DIR="$HOME/.local/share/icons/hicolor"
            mkdir -p "$ICON_THEME_DIR/64x64/apps" "$ICON_THEME_DIR/512x512/apps"

            # Prefer the official icon shipped inside the AFFiNE package.
            # If it can't be extracted (missing npx/asar), fall back to a placeholder.
            ASAR_PATH="$AFFINE_DIR/AFFiNE-linux-x64/resources/app.asar"
            if command -v npx &>/dev/null && [ -f "$ASAR_PATH" ]; then
                npx --yes asar extract-file "$ASAR_PATH" resources/icons/icon_stable_512x512.png "$ICON_THEME_DIR/512x512/apps/affine.png" 2>/dev/null || true
                npx --yes asar extract-file "$ASAR_PATH" resources/icons/icon_stable_64x64.png "$ICON_THEME_DIR/64x64/apps/affine.png" 2>/dev/null || true
            fi

            # Fallback placeholder (won't overwrite an existing official icon)
            if [ ! -f "$ICON_THEME_DIR/512x512/apps/affine.png" ]; then
                cat > "$ICON_THEME_DIR/512x512/apps/affine.png" <<'PNG'
<svg xmlns="http://www.w3.org/2000/svg" width="256" height="256" viewBox="0 0 256 256">
  <rect width="256" height="256" rx="48" ry="48" fill="#2d2f36" />
  <text x="50%" y="52%" font-family="sans-serif" font-weight="700" font-size="140" fill="#ffffff" text-anchor="middle" dominant-baseline="middle">A</text>
</svg>
PNG
            fi

            cat > "$HOME/.local/share/applications/affine.desktop" << EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=AFFiNE
Comment=Universal editor for work and creation
Exec=$HOME/.nkermani/bin/affine --kiosk %U
Icon=affine
Terminal=false
StartupNotify=true
Categories=Utility;Development
MimeType=text/plain;application/json;
EOF
            echo "  ✅ Created desktop entry for AFFiNE"

            # Update icon cache so the new icon appears in launchers
            if command -v gtk-update-icon-cache &>/dev/null; then
                gtk-update-icon-cache -q -t -f "$ICON_THEME_DIR" || true
            fi
        fi
    else
        echo "  ⚠️  Affine binary not found after extraction:" >&2
        ls -la "$AFFINE_DIR" >&2
    fi

    rm -f "$AFFINE_ARCHIVE"
fi

# VSCode Desktop Entry & Default Apps (Linux 42 only)
if [[ "$IS_42" == "true" && "$OS_TYPE" == "Linux" && "$IS_WSL" != "true" && -d "$APPS_DIR/vscode" ]]; then
    echo "  📱 Setting up VSCode desktop entry for Linux 42..."

    # Create desktop entry
    mkdir -p "$HOME/.local/share/applications"
    cat > "$HOME/.local/share/applications/code.desktop" << EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=Visual Studio Code
Comment=Code Editing. Redefined.
GenericName=Text Editor
Exec=$HOME/.nkermani/apps/vscode/bin/code
Icon=$HOME/.nkermani/apps/vscode/resources/app/resources/linux/code.png
Terminal=false
StartupNotify=false
StartupWMClass=Code
Categories=TextEditor;Development;IDE;
MimeType=application/x-code-workspace;
Keywords=vscode;code;editor;
EOF

    # Set as default for text files and code
    mkdir -p "$HOME/.config"
    cat > "$HOME/.config/mimeapps.list" << 'EOF'
[Default Applications]
text/html=firefox_firefox.desktop
x-scheme-handler/http=firefox_firefox.desktop
x-scheme-handler/https=firefox_firefox.desktop
x-scheme-handler/about=firefox_firefox.desktop
x-scheme-handler/unknown=firefox_firefox.desktop
text/plain=code.desktop
text/x-python=code.desktop
text/x-c=code.desktop
text/x-c++src=code.desktop
text/x-c++hdr=code.desktop
text/x-java=code.desktop
text/x-js=code.desktop
text/x-typescript=code.desktop
text/x-shellscript=code.desktop
text/x-php=code.desktop
text/x-ruby=code.desktop
text/x-go=code.desktop
text/x-rustsrc=code.desktop
application/x-python=code.desktop
application/json=code.desktop
application/xml=code.desktop

[Added Associations]
image/jpeg=gimp.desktop;
text/plain=code.desktop;
text/x-python=code.desktop;
text/x-c=code.desktop;
text/x-c++src=code.desktop;
text/x-java=code.desktop;
text/x-js=code.desktop;
text/x-typescript=code.desktop;
text/x-shellscript=code.desktop;
application/json=code.desktop;
EOF

    # Update desktop database
    update-desktop-database "$HOME/.local/share/applications" 2>/dev/null || true

    # Update GNOME favorites
    if command -v gsettings &>/dev/null; then
        gsettings set org.gnome.shell favorite-apps "['kitty.desktop', 'firefox_firefox.desktop', 'code.desktop', 'discord.desktop']" 2>/dev/null || true
    fi

    echo "  ✅ VSCode desktop entry configured"
fi

# OpenCode.ai & Oh My OpenCode
if [ ! -d "$APPS_DIR/opencode" ]; then
    echo "  🤖 Installing OpenCode.ai (Local installation)..."
    mkdir -p "$APPS_DIR/opencode"
    # Run the official installer within the apps directory to keep it portable
    (cd "$APPS_DIR" && curl -fsSL https://opencode.ai/install | bash)
    # Create symlinks in your personal bin directory
    ln -sf "$APPS_DIR/opencode/bin/opencode" "$BIN_DIR/opencode"
    echo "  ✅ OpenCode.ai installed"
fi

# Bun (for oh-my-opencode)
if ! command -v bun &>/dev/null; then
    echo "  🍞 Installing Bun..."
    export BUN_INSTALL="$APPS_DIR/bun"
    curl -fsSL https://bun.sh/install | bash
    ln -sf "$BUN_INSTALL/bin/bun" "$BIN_DIR/bun"
    ln -sf "$BUN_INSTALL/bin/bunx" "$BIN_DIR/bunx"
fi

if command -v opencode &>/dev/null; then
    if ! opencode --version 2>&1 | grep -q "oh-my-opencode"; then
        echo "  ✨ Installing Oh My OpenCode..."
        if command -v bunx &>/dev/null; then
            bunx oh-my-opencode install --no-tui --claude=no --openai=no --gemini=no --copilot=yes
        elif command -v npx &>/dev/null; then
            npx oh-my-opencode install --no-tui --claude=no --openai=no --gemini=no --copilot=yes
        fi
    fi
fi

