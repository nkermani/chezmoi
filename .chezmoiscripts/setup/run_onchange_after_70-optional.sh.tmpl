#!/bin/bash
{{ include ".chezmoitemplates/env.sh.tmpl" }}

# --- PERSONAL DATA (Notes) ---
echo "📓 Syncing knowledge base..."
NOTES_DIR="$NK_DIR/notes"
if [ ! -d "$NOTES_DIR/.git" ]; then
    git clone "git@github.com:nkermani/notes.git" "$NOTES_DIR" || echo "  ⚠️  Notes clone failed. Check SSH keys."
fi

# --- OPTIONAL TOOLS (Yazi) ---

# 4. Yazi File Manager
echo "📂 Checking Yazi..."
if [[ "$OS_TYPE" == "Darwin" ]]; then
    if command -v brew &>/dev/null && ! command -v yazi &>/dev/null; then
        brew install yazi
    fi
else
    # Manual installation for Linux/42
    if [ ! -f "$BIN_DIR/yazi" ]; then
        echo "  📦 Installing Yazi..."
        YAZI_VER=$(curl -sI "https://github.com/sxyazi/yazi/releases/latest" | grep -i "location:" | awk -F "/" '{print $NF}' | tr -d '\r')
        local YAZI_ARCH="x86_64"
        [[ "$ARCH_TYPE" == "aarch64" || "$ARCH_TYPE" == "arm64" ]] && YAZI_ARCH="aarch64"
        curl -L -o /tmp/yazi.zip "https://github.com/sxyazi/yazi/releases/download/${YAZI_VER}/yazi-${YAZI_ARCH}-unknown-linux-musl.zip"
        unzip -q -o /tmp/yazi.zip -d /tmp
        YAZI_DIR=$(find /tmp -maxdepth 1 -type d -name "yazi-*-linux-musl" | head -n 1)
        if [ -d "$YAZI_DIR" ]; then
            mv "$YAZI_DIR/yazi" "$BIN_DIR/"
            [ -f "$YAZI_DIR/ya" ] && mv "$YAZI_DIR/ya" "$BIN_DIR/"
            rm -rf "$YAZI_DIR" /tmp/yazi.zip
        fi
    fi
fi

# --- OPTIONAL TOOLS (Browsers) ---
echo "🌐 Checking browsers..."

# Logseq (desktop)
if [ ! -f "$BIN_DIR/logseq" ]; then
    echo "  🗒️ Installing Logseq..."
    LOGSEQ_DIR="$APPS_DIR/logseq"
    mkdir -p "$LOGSEQ_DIR"

    # Resolve the latest Logseq download URL using the GitHub API
    if [[ "$ARCH_TYPE" == "aarch64" || "$ARCH_TYPE" == "arm64" ]]; then
        LOGSEQ_URL=$(curl -fsSL "https://api.github.com/repos/logseq/logseq/releases/latest" \
            | grep -E '"browser_download_url"' \
            | grep -i 'Logseq-linux-arm64.*\.zip' \
            | head -n 1 \
            | cut -d '"' -f 4)
    else
        LOGSEQ_URL=$(curl -fsSL "https://api.github.com/repos/logseq/logseq/releases/latest" \
            | grep -E '"browser_download_url"' \
            | grep -i 'Logseq-linux-x64.*\.zip' \
            | head -n 1 \
            | cut -d '"' -f 4)
    fi

    if [ -z "$LOGSEQ_URL" ]; then
        echo "  ⚠️  Could not determine latest Logseq download URL."
        LOGSEQ_URL=""
    fi

    LOGSEQ_ARCHIVE="/tmp/logseq.zip"
    if [ -n "$LOGSEQ_URL" ]; then
        curl -fsSL "$LOGSEQ_URL" -o "$LOGSEQ_ARCHIVE" || {
            echo "  ⚠️  Failed to download Logseq from $LOGSEQ_URL"
            LOGSEQ_ARCHIVE=""
        }
    fi

    if [ -f "$LOGSEQ_ARCHIVE" ]; then
        rm -rf "$LOGSEQ_DIR"/*
        unzip -oq "$LOGSEQ_ARCHIVE" -d "$LOGSEQ_DIR"

        # Attempt to locate the binary and symlink it
        LOGSEQ_BIN=$(find "$LOGSEQ_DIR" -maxdepth 3 -type f -iname 'logseq' | head -n 1)
        if [ -n "$LOGSEQ_BIN" ]; then
            ln -sf "$LOGSEQ_BIN" "$BIN_DIR/logseq"
            chmod +x "$BIN_DIR/logseq"
            echo "  ✅ Logseq installed to $BIN_DIR/logseq"
        else
            echo "  ⚠️  Could not find Logseq binary after extraction."
        fi

        rm -f "$LOGSEQ_ARCHIVE"
    fi
fi

# Firefox
if ! command -v firefox &>/dev/null; then
    echo "  🌍 Installing Firefox..."
    if [[ "$HAS_SUDO" == "true" ]]; then
        if command -v apt-get &>/dev/null; then
            sudo apt-get update -y
            sudo apt-get install -y firefox
        elif command -v dnf &>/dev/null; then
            sudo dnf install -y firefox
        elif command -v pacman &>/dev/null; then
            sudo pacman -Sy --noconfirm firefox
        elif command -v zypper &>/dev/null; then
            sudo zypper install -y firefox
        else
            echo "  ⚠️  Could not find a supported package manager to install Firefox."
        fi
    else
        echo "  ⚠️  firefox is not installed and sudo is unavailable."
    fi
fi


