{{- if (and (eq .chezmoi.os "linux") (not (.chezmoi.kernel.osrelease | lower | contains "microsoft"))) -}}
#!/bin/bash

# Configuration Performance Linux (X11/GNOME)
# Delay: 2000 | Rate: 100   (Hz)

echo "🚀 Optimisation Linux (Keyboard & Mouse)..."

# 1. Clavier (via xset pour X11, commun à 42)
if command -v xset >/dev/null; then
    xset r rate 200 100  # stored: fast (200ms delay, 100Hz rate)
    # xset r rate 500 30    # default
fi

# 2. GNOME (gsettings - pas besoin de sudo)
if command -v gsettings >/dev/null; then
    # Clavier
    gsettings set org.gnome.desktop.peripherals.keyboard delay 200      # stored: fast
    gsettings set org.gnome.desktop.peripherals.keyboard repeat-interval 10  # stored: fast
    # gsettings set org.gnome.desktop.peripherals.keyboard delay 500       # default
    # gsettings set org.gnome.desktop.peripherals.keyboard repeat-interval 50  # default

    # Souris : Profil "Flat" pour supprimer l'accélération
    gsettings set org.gnome.desktop.peripherals.mouse acceleration-profile 'flat'
    gsettings set org.gnome.desktop.peripherals.mouse speed 0

